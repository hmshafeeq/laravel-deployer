{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hmshafeeq/laravel-deployer/deploy.schema.json",
  "title": "Laravel Deployer Configuration",
  "description": "Configuration schema for Laravel Deployer package",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for IDE support"
    },
    "keepReleases": {
      "type": "integer",
      "default": 3,
      "minimum": 1,
      "description": "Number of releases to keep on the server"
    },
    "phpBinary": {
      "type": "string",
      "default": "php",
      "description": "Path to PHP binary on the server"
    },
    "display": {
      "type": "object",
      "description": "Display and confirmation settings",
      "properties": {
        "showDiff": {
          "type": "boolean",
          "default": true,
          "description": "Show files that will be synced before deployment"
        },
        "confirmChanges": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before uploading changes"
        },
        "showUploadProgress": {
          "type": "boolean",
          "default": true,
          "description": "Show upload progress during deployment"
        },
        "diffDisplayLimit": {
          "type": "integer",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of files to display per category in diff"
        }
      }
    },
    "ssh": {
      "type": "object",
      "description": "SSH connection settings",
      "properties": {
        "strictHostKeyChecking": {
          "type": "boolean",
          "default": true,
          "description": "Enable SSH strict host key checking (recommended for security)"
        }
      }
    },
    "assets": {
      "type": "object",
      "description": "Frontend asset build settings",
      "properties": {
        "failOnError": {
          "type": "boolean",
          "default": true,
          "description": "Fail deployment if asset build fails"
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "description": "Post-deployment health check configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable health check verification after deployment"
        },
        "url": {
          "type": "string",
          "description": "Health check URL (relative path like '/health' or full URL)"
        },
        "timeout": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "description": "Request timeout in seconds"
        },
        "expectedStatus": {
          "type": "integer",
          "default": 200,
          "description": "Expected HTTP status code"
        },
        "retries": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "description": "Number of retry attempts"
        },
        "retryDelay": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "description": "Delay between retries in seconds"
        },
        "endpoints": {
          "type": "array",
          "description": "Additional endpoints to check (for pre-deployment checks)",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "url": { "type": "string" },
                  "status": { "type": "integer", "default": 200 }
                },
                "required": ["url"]
              }
            ]
          }
        }
      }
    },
    "rsync": {
      "type": "object",
      "description": "Rsync file synchronization settings",
      "properties": {
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Patterns to exclude from sync. Use leading slash for root-only (e.g., '/vendor/' excludes only root vendor, not public/vendor/)"
        },
        "include": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Patterns to include (processed before excludes)"
        },
        "flags": {
          "type": "string",
          "default": "rzc",
          "description": "Rsync flags (r=recursive, z=compress, c=checksum)"
        },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["delete", "delete-after", "compress"],
          "description": "Additional rsync options"
        }
      }
    },
    "composer": {
      "type": "object",
      "description": "Composer installation settings",
      "properties": {
        "options": {
          "type": "string",
          "default": "--prefer-dist --no-interaction --optimize-autoloader",
          "description": "Composer install options"
        }
      }
    },
    "environments": {
      "type": "object",
      "description": "Environment-specific configurations",
      "additionalProperties": {
        "type": "object",
        "description": "Environment configuration (inherits and overrides global settings)",
        "properties": {
          "extends": {
            "type": "string",
            "description": "Inherit configuration from another environment (e.g., 'staging' extends 'production')"
          },
          "local": {
            "type": "boolean",
            "default": false,
            "description": "Use local execution instead of SSH"
          },
          "deployPath": {
            "type": "string",
            "description": "Deployment path on the server"
          },
          "composer": {
            "type": "object",
            "properties": {
              "options": {
                "type": "string",
                "description": "Override composer options for this environment"
              }
            }
          },
          "rsync": {
            "type": "object",
            "description": "Override rsync settings for this environment"
          },
          "display": {
            "type": "object",
            "description": "Override display settings for this environment"
          }
        }
      }
    },
    "postDeploy": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Artisan commands to run after deployment (e.g., 'config:cache', 'route:cache')"
    },
    "hooks": {
      "type": "object",
      "description": "Deployment hooks - custom commands to run at specific points during deployment",
      "properties": {
        "before:deploy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before deployment starts"
        },
        "after:setup": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after deployment structure is created"
        },
        "before:build": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before assets are built"
        },
        "after:build": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after assets are built"
        },
        "before:sync": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before files are synced"
        },
        "after:sync": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after files are synced"
        },
        "before:composer": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before composer install"
        },
        "after:composer": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after composer install"
        },
        "before:migrate": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before database migrations"
        },
        "after:migrate": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after database migrations"
        },
        "before:symlink": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run before release is symlinked"
        },
        "after:symlink": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after release is symlinked"
        },
        "after:deploy": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run after deployment completes"
        },
        "on:failure": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Commands to run when deployment fails"
        }
      }
    }
  },
  "required": ["environments"]
}
