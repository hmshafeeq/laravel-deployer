{
    "name": "shaf/laravel-deployer",
    "description": "Laravel package for deployment automation with Deployer",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Muhammad Shafeeq",
            "email": "hmshafeeq@users.noreply.github.com"
        }
    ],
    "homepage": "https://github.com/hmshafeeq/laravel-deployer",
    "keywords": [
        "laravel",
        "deployment",
        "deployer",
        "automation"
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "spatie/ssh": "^1.0",
        "symfony/yaml": "^7.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Shaf\\LaravelDeployer\\": "src/"
        },
        "files": [
            "helpers/deployment.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Shaf\\LaravelDeployer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shaf\\LaravelDeployer\\LaravelDeployerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}